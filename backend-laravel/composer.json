{
  "name": "warqna/laravel-platform",
  "description": "Warqna Zone Laravel multiplayer card platform core",
  "type": "project",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^11.0",
    "laravel/sanctum": "^4.0"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "nunomaduro/collision": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Seeders\\": "database/seeders/"
    },
    "files": [
      "app/helpers.php"
    ]
  },
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ],
    "post-autoload-dump": []
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "audit": {
      "block-insecure": false
    }
  }
}
