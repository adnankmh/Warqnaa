APP_NAME="Warqna"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.warqna.example
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
TRUSTED_PROXIES=*

WARQNA_VERSION=1.54.0
WARQNA_BUILD=154
FRONTEND_URL=https://app.warqna.example
CORS_ALLOWED_ORIGINS=https://app.warqna.example,https://www.warqna.example
SUPPORT_EMAIL=support@warqna.example
SUPPORT_URL=https://www.warqna.example/support
PRIVACY_URL=https://www.warqna.example/privacy
TERMS_URL=https://www.warqna.example/terms

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=warqna
DB_USERNAME=warqna
DB_PASSWORD=CHANGE_ME_DATABASE_PASSWORD

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

SANCTUM_STATEFUL_DOMAINS=app.warqna.example
SESSION_DOMAIN=.warqna.example
SESSION_SECURE_COOKIE=true

ADMIN_USERNAME=Adnan
ADMIN_EMAIL=admin@warqna.example
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

ACCOUNT_DELETION_GRACE_DAYS=7
INACTIVE_ACCOUNT_PURGE_DAYS=30
INACTIVE_ACCOUNT_DRY_RUN=true
ALLOW_LOCAL_DEMO_MODE=false
TOKEN_TRANSFER_FEE_PERCENT=10

VOICE_STUN_URLS=stun:stun.l.google.com:19302
VOICE_TURN_URLS=turn:turn.warqna.example:3478?transport=udp,turn:turn.warqna.example:3478?transport=tcp
VOICE_TURN_USERNAME=CHANGE_ME_TURN_USER
VOICE_TURN_CREDENTIAL=CHANGE_ME_TURN_SECRET

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@warqna.example
MAIL_FROM_NAME="Warqna"

HEALTH_SHOW_COUNTS=false
