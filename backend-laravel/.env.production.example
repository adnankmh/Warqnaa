APP_NAME="Warqna"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.warqna.example
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
TRUSTED_PROXIES=*

WARQNA_VERSION=0.5.0
WARQNA_BUILD=500
FRONTEND_URL=https://app.warqna.example
CORS_ALLOWED_ORIGINS=https://app.warqna.example,https://www.warqna.example
SUPPORT_EMAIL=support@warqna.example
SUPPORT_URL=https://www.warqna.example/support
PRIVACY_URL=https://www.warqna.example/privacy
TERMS_URL=https://www.warqna.example/terms

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=warqna
DB_USERNAME=warqna
DB_PASSWORD=CHANGE_ME_DATABASE_PASSWORD

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

SANCTUM_STATEFUL_DOMAINS=app.warqna.example
SESSION_DOMAIN=.warqna.example
SESSION_SECURE_COOKIE=true

ADMIN_USERNAME=Adnan
ADMIN_EMAIL=admin@warqna.example
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

ACCOUNT_DELETION_GRACE_DAYS=30
ALLOW_LOCAL_DEMO_MODE=false
TOKEN_TRANSFER_FEE_PERCENT=10

VOICE_STUN_URLS=stun:stun.l.google.com:19302
VOICE_TURN_URLS=turn:turn.warqna.example:3478?transport=udp,turn:turn.warqna.example:3478?transport=tcp
VOICE_TURN_USERNAME=CHANGE_ME_TURN_USER
VOICE_TURN_CREDENTIAL=CHANGE_ME_TURN_SECRET

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@warqna.example
MAIL_FROM_NAME="Warqna"

HEALTH_SHOW_COUNTS=false

# Social sign-in. Create apps in each provider console and register the exact callback URLs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/auth/social/google/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=${APP_URL}/auth/social/facebook/callback
FACEBOOK_GRAPH_VERSION=v22.0
APPLE_SERVICE_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=${APP_URL}/auth/social/apple/callback

# Firebase Cloud Messaging HTTP v1 (keep service-account credentials only on the server)
PUSH_NOTIFICATIONS_ENABLED=true
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_B64=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_HTTP_TIMEOUT=12
FIREBASE_ANDROID_CHANNEL_ID=warqna_messages

WARQNA_SEED_DEMO_USERS=false
