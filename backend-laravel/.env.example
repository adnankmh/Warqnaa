APP_NAME="Warqnaa"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8006
WARQNA_VERSION=0.3.1
WARQNA_BUILD=182
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

SOCKET_HOST=127.0.0.1
SOCKET_PORT=4000
ADMIN_USERNAME=Adnan
ADMIN_EMAIL=adnanasd63@gmail.com
ADMIN_PASSWORD=Adnan123

# Flutter Web / GitHub Pages API access. Use * for testing, then restrict to your domains.
CORS_ALLOWED_ORIGINS=*
FRONTEND_URL=http://127.0.0.1:8088

# Voice rooms (WebRTC). STUN is enough for local testing; production should use TURN.
VOICE_STUN_URLS=stun:stun.l.google.com:19302
VOICE_TURN_URLS=
VOICE_TURN_USERNAME=
VOICE_TURN_CREDENTIAL=

# Production readiness
SUPPORT_EMAIL=support@warqna.example
SUPPORT_URL=/legal/support
PRIVACY_URL=/legal/privacy
TERMS_URL=/legal/terms
ACCOUNT_DELETION_GRACE_DAYS=30
ALLOW_LOCAL_DEMO_MODE=false
TOKEN_TRANSFER_FEE_PERCENT=10

HEALTH_SHOW_COUNTS=true

# Social sign-in. Create apps in each provider console and register the exact callback URLs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/auth/social/google/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=${APP_URL}/auth/social/facebook/callback
FACEBOOK_GRAPH_VERSION=v22.0
APPLE_SERVICE_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=${APP_URL}/auth/social/apple/callback

# Firebase Cloud Messaging HTTP v1 (optional but required for alerts while app is closed)
PUSH_NOTIFICATIONS_ENABLED=true
FIREBASE_PROJECT_ID=
# Recommended: base64-encode the complete Firebase service-account JSON and place it here.
FIREBASE_SERVICE_ACCOUNT_B64=
# Alternative options (use one only):
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_HTTP_TIMEOUT=12
FIREBASE_ANDROID_CHANNEL_ID=warqna_messages
