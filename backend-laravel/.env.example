APP_NAME="Warqna Zone"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8006
WARQNA_VERSION=1.56.0
WARQNA_BUILD=156
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

SOCKET_HOST=127.0.0.1
SOCKET_PORT=4000
ADMIN_USERNAME=Adnan
ADMIN_EMAIL=adnanasd63@gmail.com
ADMIN_PASSWORD=Adnan123

# Flutter Web / GitHub Pages API access. Use * for testing, then restrict to your domains.
CORS_ALLOWED_ORIGINS=*
FRONTEND_URL=http://127.0.0.1:8088

# Voice rooms (WebRTC). STUN is enough for local testing; production should use TURN.
VOICE_STUN_URLS=stun:stun.l.google.com:19302
VOICE_TURN_URLS=
VOICE_TURN_USERNAME=
VOICE_TURN_CREDENTIAL=

# Production readiness
SUPPORT_EMAIL=support@warqna.example
SUPPORT_URL=/legal/support
PRIVACY_URL=/legal/privacy
TERMS_URL=/legal/terms
ACCOUNT_DELETION_GRACE_DAYS=7
INACTIVE_ACCOUNT_PURGE_DAYS=30
INACTIVE_ACCOUNT_DRY_RUN=true
ALLOW_LOCAL_DEMO_MODE=true
TOKEN_TRANSFER_FEE_PERCENT=10

HEALTH_SHOW_COUNTS=true
