{
  "scripts": {
    "socket": "node server/index.js",
    "socket:dev": "nodemon server/index.js",
    "cap:init": "npx cap init \"Warqna Zone\" \"com.warqna.zone\" --web-dir=public",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "apk:prepare": "npm install && npm run cap:sync",
    "pwa:check": "node tools/pwa-check.js && node tools/mobile-app-check.js",
    "apk:github": "echo Push this project to GitHub, then run the Build Warqna APK workflow from Actions.",
    "apk:local": "npm install && npm run pwa:check && npx cap sync android",
    "android:config": "node tools/prepare-capacitor-config.js",
    "android:sync": "npm run android:config && npx cap sync android",
    "android:add": "npx cap add android",
    "android:cloud-ready": "node tools/mobile-app-check.js",
    "mobile:check": "node tools/mobile-app-check.js"
  },
  "dependencies": {
    "socket.io": "^4.7.5",
    "express": "^4.18.3",
    "cors": "^2.8.5",
    "@capacitor/core": "^6.2.0",
    "@capacitor/android": "^6.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "@capacitor/cli": "^6.2.0"
  },
  "name": "warqna-zone",
  "version": "1.39.0",
  "description": "Warqna Zone Laravel PWA and Android cloud-build wrapper without local Android Studio"
}